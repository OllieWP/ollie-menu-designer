{
	"name": "ollie-menu-designer",
	"version": "0.2.7",
	"description": "Design custom mega menus and mobile menus for WordPress.",
	"author": "Mike McAlister",
	"license": "GPL-3.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --experimental-modules",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"lint:js:src": "wp-scripts lint-js ./src",
		"lint:js:src:fix": "wp-scripts lint-js ./src --fix",
		"start": "wp-scripts start --experimental-modules",
		"packages-update": "wp-scripts packages-update",
		"update-pot": "wp i18n make-pot . languages/menu-designer.pot --exclude=src,build,node_modules",
		"plugin-zip": "npm run plugin-zip && copyfiles --verbose menu-designer.zip _playground/ && rm menu-designer.zip"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.27.0",
		"copyfiles": "^2.4.1"
	},
        "dependencies": {
                "@wordpress/icons": "^11.1.0"
        },
        "overrides": {
                "minimatch": "^10.2.4",
                "serialize-javascript": "^7.0.4",
                "webpack-dev-server": "^5.2.3",
                "webpack": "^5.105.0",
                "axios": "^1.13.5",
                "basic-ftp": "^5.2.0",
                "immutable": "^5.1.5",
                "js-yaml": "^4.1.1",
                "node-forge": "^1.3.2",
                "qs": "^6.14.2",
                "svgo": "^3.3.3",
                "ajv": "^8.18.0",
                "lodash": "^4.17.22",
                "lodash-es": "^4.17.23",
                "@tootallnate/once": "^3.0.1"
        }
}
